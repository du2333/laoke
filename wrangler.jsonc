{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "laoke",
  "main": "worker/index.ts",
  "compatibility_date": "2025-09-27",
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"],
  },
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "custom_domain": true,
      "pattern": "laoke.dukda.com",
    },
  ],
}
