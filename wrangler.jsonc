{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "laoke",
  "compatibility_date": "2026-04-23",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server-entry.ts",
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "laoke.dukda.com/*",
      "zone_name": "dukda.com",
    },
  ],
}
